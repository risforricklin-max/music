<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Green New Year 學習簡報</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* 引入適合國小學童閱讀的工整字體 */
        @import url('https://fonts.googleapis.com/css2?family=Comic+Neue:wght@700&family=Noto+Sans+TC:wght@500;700&display=swap');

        body {
            font-family: 'Comic Neue', 'Noto Sans TC', sans-serif;
            overflow: hidden;
            background-color: #f0fdf4; /* 淺綠色背景 */
        }

        .slide-container {
            position: relative;
            height: 100vh;
            width: 100vw;
        }

        .slide {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 100%;
            display: none;
            padding: 3rem;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            transition: all 0.5s ease-in-out;
            background-image: radial-gradient(circle at center, rgba(255,255,255,0.8) 0%, transparent 100%);
        }

        .slide.active {
            display: flex;
            animation: fadeIn 0.8s;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* 歌詞文字：至少 30pt (約 40px)，此處使用 4.5rem (約 72px) */
        .lyrics-text {
            font-size: 4.5rem;
            font-weight: 700;
            line-height: 1.3;
            color: #166534;
            margin-bottom: 1.5rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }

        /* 彩虹動畫特效 */
        .rainbow-header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 12px;
            background: linear-gradient(90deg, #ff0000, #ff7f00, #ffff00, #00ff00, #0000ff, #4b0082, #8f00ff);
            background-size: 200% 100%;
            animation: rainbowMove 4s linear infinite;
            z-index: 1000;
        }

        @keyframes rainbowMove {
            0% { background-position: 0% 50%; }
            100% { background-position: 200% 50%; }
        }

        /* 播放按鈕 */
        .audio-control {
            position: fixed;
            top: 25px;
            right: 25px;
            z-index: 1001;
            padding: 12px 24px;
            background: white;
            border: 4px solid #166534;
            border-radius: 999px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s;
        }

        .audio-control:hover { transform: scale(1.05); background-color: #f0fdf4; }

        /* 導覽按鈕 */
        .nav-btn {
            position: fixed;
            bottom: 40px;
            z-index: 1000;
            background: #166534;
            color: white;
            padding: 15px 35px;
            border-radius: 20px;
            font-size: 1.5rem;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.3s;
        }
        .nav-btn:hover { background: #15803d; }
        .prev-btn { left: 40px; }
        .next-btn { right: 40px; }

        .slide-indicator {
            position: fixed;
            bottom: 20px;
            width: 100%;
            text-align: center;
            color: #166534;
            font-weight: bold;
        }

        .icon-bounce { animation: bounce 2s infinite; font-size: 8rem; margin-bottom: 2rem; }
        @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

        .card { background: white; border: 4px solid #bbf7d0; border-radius: 24px; padding: 20px; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
    </style>
</head>
<body>

    <div class="rainbow-header"></div>

    <!-- 背景音樂 -->
    <button class="audio-control" id="toggleMusic">
        <span id="musicIcon">🎵</span>
        <span id="musicText">播放歌曲</span>
    </button>
    <audio id="player" loop>
        <source src="https://raw.githubusercontent.com/hongruhuang29-arch/music-mp3/main/River%20of%20Tomorrows%20(Cover).mp3" type="audio/mpeg">
    </audio>

    <div class="slide-container">
        <!-- 第1部分：標題頁 -->
        <div class="slide active">
            <div class="icon-bounce">🌏</div>
            <h1 class="text-7xl font-bold text-green-800 mb-4">Green New Year</h1>
            <p class="text-3xl text-green-600">兒歌英語學習簡報</p>
        </div>

        <!-- 第1部分：歌詞教學 (1/3) -->
        <div class="slide">
            <p class="text-2xl text-green-500 font-bold mb-8 italic">歌詞教學 Part 1</p>
            <div class="lyrics-text">Happy Green New Year.</div>
            <div class="lyrics-text">Plant a little tree.</div>
            <div class="lyrics-text">Save the blue earth.</div>
            <div class="lyrics-text">For you and me.</div>
        </div>

        <!-- 第1部分：歌詞教學 (2/3) - Chorus -->
        <div class="slide">
            <p class="text-2xl text-green-500 font-bold mb-8 italic">歌詞教學 Part 2 (Chorus)</p>
            <div class="lyrics-text">Green is so clean.</div>
            <div class="lyrics-text">Green is so bright.</div>
            <div class="lyrics-text">Love the world today.</div>
            <div class="lyrics-text">Do what is right.</div>
        </div>

        <!-- 第1部分：歌詞教學 (3/3) - Verse 2 & Repeat Chorus -->
        <div class="slide">
            <p class="text-2xl text-green-500 font-bold mb-8 italic">歌詞教學 Part 3</p>
            <div class="lyrics-text">No more plastic bags.</div>
            <div class="lyrics-text">Recycle all the cans.</div>
            <div class="lyrics-text">Help the nature grow.</div>
            <div class="lyrics-text">Green is so clean.</div>
            <div class="lyrics-text">Green is so bright.</div>
        </div>

        <!-- 第2部分：全歌詞中英翻譯 (1/2) -->
        <div class="slide">
            <h2 class="text-4xl font-bold text-green-900 mb-10 underline">全歌詞翻譯 (上)</h2>
            <div class="grid grid-cols-2 gap-y-6 text-left max-w-5xl">
                <div class="text-3xl font-bold">Happy Green New Year.</div>
                <div class="text-3xl text-green-700">快樂綠色新年。</div>
                <div class="text-3xl font-bold">Plant a little tree.</div>
                <div class="text-3xl text-green-700">種下一棵小樹。</div>
                <div class="text-3xl font-bold">Save the blue earth.</div>
                <div class="text-3xl text-green-700">拯救藍色地球。</div>
                <div class="text-3xl font-bold">For you and me.</div>
                <div class="text-3xl text-green-700">為了你和我。</div>
            </div>
        </div>

        <!-- 第2部分：全歌詞中英翻譯 (2/2) -->
        <div class="slide">
            <h2 class="text-4xl font-bold text-green-900 mb-10 underline">全歌詞翻譯 (下)</h2>
            <div class="grid grid-cols-2 gap-y-6 text-left max-w-5xl">
                <div class="text-3xl font-bold">Green is so clean.</div>
                <div class="text-3xl text-green-700">綠色是如此乾淨。</div>
                <div class="text-3xl font-bold">Green is so bright.</div>
                <div class="text-3xl text-green-700">綠色是如此明亮。</div>
                <div class="text-3xl font-bold">No more plastic bags.</div>
                <div class="text-3xl text-green-700">不再使用塑膠袋。</div>
                <div class="text-3xl font-bold">Do what is right.</div>
                <div class="text-3xl text-green-700">做正確的事情。</div>
            </div>
        </div>

        <!-- 第3部分：重要單字教學 -->
        <div class="slide">
            <h2 class="text-5xl font-bold text-green-900 mb-10">重要單字教學</h2>
            <div class="grid grid-cols-3 gap-8">
                <div class="card">
                    <div class="text-6xl mb-4">🌳</div>
                    <p class="text-3xl font-bold text-green-800">Plant</p>
                    <p class="text-xl text-gray-600">種植</p>
                </div>
                <div class="card">
                    <div class="text-6xl mb-4">♻️</div>
                    <p class="text-3xl font-bold text-green-800">Recycle</p>
                    <p class="text-xl text-gray-600">回收</p>
                </div>
                <div class="card">
                    <div class="text-6xl mb-4">🛍️</div>
                    <p class="text-3xl font-bold text-green-800">Plastic</p>
                    <p class="text-xl text-gray-600">塑膠</p>
                </div>
            </div>
        </div>

        <!-- 第3部分：重要句子教學 -->
        <div class="slide">
            <h2 class="text-5xl font-bold text-green-900 mb-10">重點句型</h2>
            <div class="space-y-8 text-left w-3/4">
                <div class="bg-yellow-50 p-8 rounded-3xl border-l-8 border-yellow-400">
                    <p class="text-3xl font-bold">"Save the blue earth."</p>
                    <p class="text-xl mt-2">意思是「拯救藍色的地球」。動詞 Save 開頭是命令句，表示鼓勵大家行動！</p>
                </div>
                <div class="bg-blue-50 p-8 rounded-3xl border-l-8 border-blue-400">
                    <p class="text-3xl font-bold">"Green is so clean."</p>
                    <p class="text-xl mt-2">意思是「綠色是如此乾淨」。形容詞 clean 用來描述環保的環境。</p>
                </div>
            </div>
        </div>

        <!-- 第3部分：背景知識 -->
        <div class="slide">
            <h2 class="text-5xl font-bold text-green-900 mb-10">小知識：什麼是綠色新年？</h2>
            <div class="bg-white p-10 rounded-3xl shadow-2xl max-w-4xl">
                <p class="text-3xl text-left leading-relaxed text-green-800">
                    新的一年，我們可以送給地球一個大禮物！<br><br>
                    1. <b>減少塑膠袋</b>：出門逛街帶上自己的袋子。<br>
                    2. <b>認真回收</b>：讓資源可以重複再利用。<br>
                    3. <b>愛護自然</b>：多看綠色的植物，少浪費水電。
                </p>
            </div>
        </div>

        <!-- 第3部分：小測驗 -->
        <div class="slide">
            <h2 class="text-5xl font-bold text-green-900 mb-10">小測驗 Quiz Time!</h2>
            <p class="text-3xl mb-12">Q: 歌詞中提到要種什麼？ (What to plant?)</p>
            <div class="flex flex-col gap-6 w-1/2">
                <button class="bg-white border-4 border-green-300 p-6 rounded-2xl text-2xl font-bold hover:bg-green-100 transition" onclick="checkAnswer(true)">A. A little tree (一棵小樹)</button>
                <button class="bg-white border-4 border-green-300 p-6 rounded-2xl text-2xl font-bold hover:bg-green-100 transition" onclick="checkAnswer(false)">B. A plastic bag (塑膠袋)</button>
            </div>
        </div>
    </div>

    <div class="slide-indicator" id="slideNum">第 1 / 11 頁</div>
    <button class="nav-btn prev-btn" id="prevBtn">上一頁</button>
    <button class="nav-btn next-btn" id="nextBtn">下一頁</button>

    <script>
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide');
        const slideNum = document.getElementById('slideNum');
        const player = document.getElementById('player');
        const toggleMusic = document.getElementById('toggleMusic');
        const musicIcon = document.getElementById('musicIcon');
        const musicText = document.getElementById('musicText');

        function updateSlide() {
            slides.forEach((s, i) => {
                s.classList.toggle('active', i === currentSlide);
            });
            slideNum.innerText = `第 ${currentSlide + 1} / ${slides.length} 頁`;
        }

        document.getElementById('nextBtn').onclick = () => {
            if (currentSlide < slides.length - 1) {
                currentSlide++;
                updateSlide();
            }
        };

        document.getElementById('prevBtn').onclick = () => {
            if (currentSlide > 0) {
                currentSlide--;
                updateSlide();
            }
        };

        // 音樂切換邏輯
        toggleMusic.onclick = () => {
            if (player.paused) {
                player.play();
                musicIcon.innerText = '⏸️';
                musicText.innerText = '暫停音樂';
            } else {
                player.pause();
                musicIcon.innerText = '🎵';
                musicText.innerText = '播放歌曲';
            }
        };

        function checkAnswer(isCorrect) {
            if (isCorrect) {
                alert('🎉 太棒了！答對囉！');
            } else {
                alert('❌ 哎呀，再看一次歌詞喔！');
            }
        }

        // 鍵盤導覽
        window.onkeydown = (e) => {
            if (e.key === 'ArrowRight' || e.key === ' ') document.getElementById('nextBtn').click();
            if (e.key === 'ArrowLeft') document.getElementById('prevBtn').click();
        };
    </script>
</body>
</html>
